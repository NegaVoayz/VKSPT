#version 460
#extension GL_EXT_ray_query : require

// =============================================================================
// Spectral constants & GPU material
// =============================================================================
const int LAMBDA_MIN           = 380;
const int LAMBDA_MAX           = 780;
const int SPECTRAL_STACK_MAX    = 256;

const int MATERIAL_DIELECTRIC = 0;
const int MATERIAL_METAL      = 1;
const int MATERIAL_LAMBERTIAN = 2;

struct GpuMaterial {
    vec4 cauchyA, cauchyB;     // refractive index: n(λ) = A + B/λ²
    vec4 absorpA, absorpB;     // absorption: α(λ) = A + B/λ² [m⁻¹]
    vec4 albedo, params;       // params: x=ior, y=rough, z=type
};

// =============================================================================
// Per-ray state for the adaptive spectral stack
// =============================================================================
struct RayState {
    vec3 origin;
    vec3 direction;
    vec3 last_split;     // accumulated lateral chromatic separation (world units)
    vec3 dispersion;     // per-unit-distance chromatic spread, ortho to direction
    int  lam_start;      // wavelength range start (nm, inclusive)
    int  lam_end;        // wavelength range end (nm, inclusive)
    float throughput;    // fraction of light surviving path losses (Legendere c0)
    float decay_c1;      // 1st Legendre coefficient of decay D(x)
    float decay_c2;      // 2nd Legendre coefficient of decay D(x)
    int  bounce;         // bounces already taken
    int  generation;     // split generation counter (0 = never split)
    bool insideGlass;    // currently inside a dielectric?
};

// =============================================================================
// Spectral math
// =============================================================================
float cauchyIOR(GpuMaterial m, float lamNm) {
    if (int(m.params.z) != MATERIAL_DIELECTRIC) return m.params.x;
    float lu = lamNm * 1e-3, l2 = lu * lu;
    return m.cauchyA.y + m.cauchyB.y / l2;
}

bool refractDir(vec3 I, vec3 N, float eta, out vec3 T) {
    float ci = -dot(I, N), st2 = eta * eta * (1.0 - ci * ci);
    if (st2 > 1.0) { T = vec3(0); return false; }
    T = eta * I + (eta * ci - sqrt(1.0 - st2)) * N;
    return true;
}
vec3 reflectDir(vec3 I, vec3 N) { return I - 2.0 * dot(I, N) * N; }

/// Evaluate Legendre expansion D(x) = c0 + c1·x + c2·(3x²−1)/2.
/// Placed here so both CIE integration and Legendre absorption can use it.
float evalDecay(float c0, float c1, float c2, float x) {
    return c0 + c1 * x + c2 * (3.0 * x * x - 1.0) * 0.5;
}

