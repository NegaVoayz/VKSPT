<?xml version="1.0" encoding="utf-8"?>
<SceneInfo>
    <RefractionMethod>
        <Args version="1"/>
    </RefractionMethod>
    
    <EnvironmentMap>
        <Args display="1"/>
    </EnvironmentMap>

    <ResourceLimits>
        <Args maxInstances="16" maxMaterials="16" maxLights="8"/>
    </ResourceLimits>
    
    <DepthMax>
        <Args DepthMax="4"/>
    </DepthMax>
    
    <Camera>
        <Args width="256" height="192" outputname="output-result-256-192.jpg"/>
    </Camera>

    <SpheresDisplay>
        <Args sphere1="0" sphere2="0" sphere3="0" sphere4="0"/>
    </SpheresDisplay>

    <Duck>
        <Args filename="duck.obj" display="0" normalinterpolation="1" rendermethod="1"/>
