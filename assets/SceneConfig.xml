        <Rotation x="0.0" y="0.0" z="0.0"/>
        <Translation x="0.0" y="0.0" z="0.0"/>
        <RefractiveIndex x="1.5"/>
        <DispersionB value="0.004"/>
        <AbsorptionA x="0.02" y="0.02" z="0.02"/>
        <AbsorptionB x="0.0" y="0.0" z="0.0"/>
        <Albedo x="0.0" y="0.5" z="0.1" w="0.8"/>
        <Diffuse r="0.6" g="0.7" b="0.8"/>
        <Shiness p="125.0"/>
    </Duck>
    
    <Asschercut>
