<?xml version="1.0" encoding="utf-8"?>
<SceneInfo>
    <RefractionMethod>
        <Args version="1"/> <!--method for computing refraction ray, 0: original version; 
                             1: our non-recursive version with total internal reflection-->
    </RefractionMethod>
    
    <RayOffsetMethod>       <!-- new item for origin offsetting of reflection and refraction rays -->
        <Args version="1"/>  <!-- 0: original version; 1: our version  -->
    </RayOffsetMethod>
    
    <EnvironmentMap>
        <Args display="1"/> <!--Environment map image, 0: not display; 1: appeared as skybox  -->
    </EnvironmentMap>
    
    <DepthMax>
        <Args DepthMax="4"/>  <!-- max recursive depth of tracing rays, must be positive number -->
    </DepthMax>
    
    <Camera>
        <Args width="256" height="192" outputname="output-result-v2-256-192-our.jpg"/>
        <!-- resolution of rendered image: width x height in pixels (4:3 ratio), try small resolution for debugging -->
        <!-- ourputname: your favorite name saving the rendered image, usually naming different ones for comparsion -->
    </Camera>
    
    <SpheresDisplay>
        <Args sphere1="0" sphere2="0" sphere3="0" sphere4="0"/> <!-- for each sphere, 0: not display; 1: appeared in scene  -->
    </SpheresDisplay>

    <Duck>
        <Args filename="duck.obj" display="0" normalinterpolation="0" rendermethod="1"/>
        <!-- filename is obj (wavefront, exported by blender) file of model; display is "1" for appeared in scene;
             normalinterpolation is "1" for smooth normal interpolation of triangle vertices using barycentric coordiantes;
             rendermethod (0,1,2, etc) for internal testing (not for students) activated when value of RefractionMethod is negative -->
        <Scale x="1.0" y="1.0" z="1.0"/>     <!-- scale values of obj model for placing it in the scene -->
        <Rotation x="0.0" y="0.0" z="0.0"/>  <!-- rotate angles around (x,y,z axis) in degree of obj model for placing it in scene -->
        <Translation x="0.0" y="0.0" z="0.0"/> <!-- translate vector of obj model for placing it in the scene -->
        <RefractiveIndex x="1.5"/>             <!-- Index of refraction of object -->  
        <Albedo x="0.0" y="0.5" z="0.1" w="0.8"/> <!-- x: scale coefficent of diffuse component of local shading, 
                                                       y: scale coefficent of specular component of local shading,
                                                       z: scale coefficent of contribution of reflection ray,
                                                       w：scale coefficent of contribution of refraction ray,
                                                       note: check source code for specific meanings-->  
        <Diffuse r="0.6" g="0.7" b="0.8"/>    <!-- multiplied with diffuse component of local shading, pleae check code -->  
        <Shiness p="125.0"/>                  <!-- shiness of specular component of local shading -->  
    </Duck>
    
    <Asschercut>
        <Args filename="asschercut-mesh.obj" display="1" normalinterpolation="0" rendermethod="1"/>
        <!--<Scale x="0.5" y="0.5" z="0.5"/>
        <Rotation x="45.0" y="45.0" z="0.0"/>
        <Translation x="0.2" y="-0.4" z="-2.0"/> -->
